---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = allArticles
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="GEG Ratgeber für Vermieter 2024 | Gebäudeenergiegesetz Leitfaden"
  description="Umfassender Ratgeber zum Gebäudeenergiegesetz (GEG) 2024 für Vermieter. Alles zu Heizungsaustausch, Sanierungspflichten, Fristen und Fördermöglichkeiten."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          GEG Ratgeber für Vermieter 2024
        </h1>
        <p class="text-xl md:text-2xl text-primary-100 mb-8">
          Ihr umfassender Leitfaden zum Gebäudeenergiegesetz. Alle wichtigen Informationen zu Pflichten, Fristen und Fördermöglichkeiten.
        </p>
        <a
          href="/artikel"
          class="inline-block bg-white text-primary-700 font-semibold px-8 py-3 rounded-lg hover:bg-primary-50 transition shadow-lg"
        >
          Alle Artikel durchsuchen
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Info Cards -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 mb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-lg shadow-md p-6">
        <div class="text-primary-600 text-3xl mb-3">⚡</div>
        <h3 class="text-xl font-bold mb-2">65%-Regel ab 2024</h3>
        <p class="text-gray-600">
          Neue Heizungen müssen zu 65% mit erneuerbaren Energien betrieben werden.
        </p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6">
        <div class="text-primary-600 text-3xl mb-3">📅</div>
        <h3 class="text-xl font-bold mb-2">Wichtige Fristen</h3>
        <p class="text-gray-600">
          Übergangsfristen bis 2026/2028 je nach Gemeindegröße beachten.
        </p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6">
        <div class="text-primary-600 text-3xl mb-3">💰</div>
        <h3 class="text-xl font-bold mb-2">Förderungen nutzen</h3>
        <p class="text-gray-600">
          Bis zu 70% Zuschuss für energetische Sanierungsmaßnahmen möglich.
        </p>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-3xl font-bold mb-8 text-gray-900">Aktuelle Artikel</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestArticles.map((article) => (
        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <h3 class="text-xl font-bold mb-3 text-gray-900">
              <a href={`/artikel/${article.slug}`} class="hover:text-primary-600 transition">
                {article.data.title}
              </a>
            </h3>
            <p class="text-gray-600 mb-4 line-clamp-3">
              {article.data.description}
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <time datetime={article.data.pubDate.toISOString()}>
                {new Intl.DateTimeFormat('de-DE', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                }).format(article.data.pubDate)}
              </time>
              <a
                href={`/artikel/${article.slug}`}
                class="text-primary-600 font-semibold hover:text-primary-700 transition"
              >
                Weiterlesen →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Key Topics -->
  <section class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 text-gray-900">Wichtige Themen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-gray-200 rounded-lg p-6 hover:border-primary-300 transition">
          <h3 class="text-xl font-bold mb-3 text-gray-900">Heizungsaustausch</h3>
          <p class="text-gray-600 mb-4">
            Alles zu den neuen Anforderungen beim Heizungstausch, zulässigen Technologien und Übergangsfristen.
          </p>
        </div>
        <div class="border border-gray-200 rounded-lg p-6 hover:border-primary-300 transition">
          <h3 class="text-xl font-bold mb-3 text-gray-900">Sanierungspflichten</h3>
          <p class="text-gray-600 mb-4">
            Welche Sanierungsmaßnahmen sind verpflichtend und welche Ausnahmen gibt es?
          </p>
        </div>
        <div class="border border-gray-200 rounded-lg p-6 hover:border-primary-300 transition">
          <h3 class="text-xl font-bold mb-3 text-gray-900">Förderprogramme</h3>
          <p class="text-gray-600 mb-4">
            Übersicht über BAFA, KfW und weitere Fördermöglichkeiten für Vermieter.
          </p>
        </div>
        <div class="border border-gray-200 rounded-lg p-6 hover:border-primary-300 transition">
          <h3 class="text-xl font-bold mb-3 text-gray-900">Energieausweis</h3>
          <p class="text-gray-600 mb-4">
            Pflichten bei Vermietung, neue Anforderungen und korrekte Verwendung des Energieausweises.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
