---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Alle Artikel | GEG Ratgeber für Vermieter"
  description="Durchsuchen Sie alle Artikel zum Gebäudeenergiegesetz (GEG) für Vermieter. Umfassende Informationen zu Heizungsaustausch, Sanierung und Förderungen."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold mb-4 text-gray-900">Alle Artikel</h1>
    <p class="text-xl text-gray-600 mb-12">
      Durchsuchen Sie alle Artikel zum Gebäudeenergiegesetz für Vermieter
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedArticles.map((article) => (
        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <h2 class="text-xl font-bold mb-3 text-gray-900">
              <a href={`/artikel/${article.slug}`} class="hover:text-primary-600 transition">
                {article.data.title}
              </a>
            </h2>
            <p class="text-gray-600 mb-4">
              {article.data.description}
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <time datetime={article.data.pubDate.toISOString()}>
                {new Intl.DateTimeFormat('de-DE', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                }).format(article.data.pubDate)}
              </time>
              <a
                href={`/artikel/${article.slug}`}
                class="text-primary-600 font-semibold hover:text-primary-700 transition"
              >
                Weiterlesen →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
